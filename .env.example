# Copy this file to  backend/.env  and fill in real values.
# NEVER commit the real .env (it's in .gitignore). Secrets stay on the backend only.

# --- Login (single account) ---
APP_USERNAME=admin
APP_PASSWORD=pick-a-strong-password
JWT_SECRET=generate-a-long-random-string

# --- Database ---
DATABASE_URL=sqlite:///./data/app.db

# --- Claude API (needed only to run the vocab generator / later grading tools) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- SRS ---
DAILY_NEW_CARDS=20

# --- CORS: where the frontend dev server runs ---
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Optional: Cloudflare Tunnel (for public HTTPS URL on the cloud VM) ---
# Create a tunnel in Cloudflare Zero Trust, paste its token here, then run:
#   docker compose --profile tunnel up -d
TUNNEL_TOKEN=
